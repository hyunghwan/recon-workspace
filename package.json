{
  "name": "recon-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Build-in-public reconciliation workspace for bookkeepers and small finance teams.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.26.0",
  "homepage": "https://reconcile.sqncs.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyunghwan/recon-workspace.git"
  },
  "bugs": {
    "url": "https://github.com/hyunghwan/recon-workspace/issues"
  },
  "keywords": [
    "reconciliation",
    "bookkeeping",
    "finance-ops",
    "firebase",
    "react",
    "vite"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/blog-check.mjs && tsc -b && vite build && node scripts/blog-render.mjs",
    "blog:check": "node scripts/blog-check.mjs",
    "blog:render": "node scripts/blog-render.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run tests/harness/config-baseline.test.ts",
    "test:firebase": "bash scripts/test-firebase.sh",
    "test:smoke": "bash scripts/test-smoke.sh",
    "release:verify": "bash scripts/release-verify.sh",
    "release:preview": "bash scripts/firebase-preview-deploy.sh",
    "release:live": "bash scripts/firebase-live-deploy.sh"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "firebase-tools": "^15.11.0",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react-grab": "^0.1.28",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.0.7"
  }
}
