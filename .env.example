VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Required for blog SEO metadata, sitemap, and RSS generation.
# Release builds must use the canonical Firebase Hosting origin.
SITE_ORIGIN=https://your-firebase-project-id.web.app

# Optional: required when Cloud Storage App Check enforcement is enabled.
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Optional: set to true only for local App Check debugging.
VITE_FIREBASE_APPCHECK_DEBUG=
