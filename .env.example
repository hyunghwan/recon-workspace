VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Required for production SEO metadata, sitemap, and RSS generation.
# On Vercel, this can be omitted because VERCEL_URL is detected automatically.
SITE_ORIGIN=http://localhost:4173

# Optional: required when Cloud Storage App Check enforcement is enabled.
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Optional: set to true only for local App Check debugging.
VITE_FIREBASE_APPCHECK_DEBUG=
