VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:replace-me

# Required for blog metadata, sitemap, RSS, and release verification.
SITE_ORIGIN=https://reconcile.sqncs.com

# Deployment scripts read these values from the shell or from .env.local when present.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PREVIEW_CHANNEL=preview

# Optional: required only when Cloud Storage App Check enforcement is enabled.
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Optional: set to true only for local App Check debugging.
VITE_FIREBASE_APPCHECK_DEBUG=
